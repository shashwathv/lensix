#!/usr/bin/env bash

# Force XWayland so PyQt6 and mss work on all Wayland compositors
export QT_QPA_PLATFORM=xcb

# Robust method to find the script's real directory, following symlinks
SOURCE=${BASH_SOURCE[0]}
while [ -L "$SOURCE" ]; do
  DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )
  SOURCE=$(readlink "$SOURCE")
  [[ $SOURCE != /* ]] && SOURCE=$DIR/$SOURCE
done
SCRIPT_DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )

VENV_PYTHON="${SCRIPT_DIR}/.venv/bin/python3"

if [ ! -f "$VENV_PYTHON" ]; then
    echo "Error: The Python virtual environment is missing. Please try re-installing."
    echo "Expected Python at: $VENV_PYTHON"
    exit 1
fi

"$VENV_PYTHON" "${SCRIPT_DIR}/search.py" "$@"
